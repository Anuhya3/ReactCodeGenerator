generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GenerationJob {
  id           String   @id @default(uuid())
  url          String?
  status       String
  componentTree String?
  code         String?
  previewHtml  String?
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
